// LayGrounded Prisma schema
// Adapted from Supabase spec to Prisma + SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyMemberships CompanyMember[]
  claims             Claim[]          @relation("ClaimCreator")
  platformRoles      UserRole[]
}

model UserRole {
  id     String  @id @default(cuid())
  userId String  @unique
  role   String  @default("member") // 'admin' | 'member'
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members CompanyMember[]
  claims  Claim[]
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      String   @default("member") // 'admin' | 'member'
  email     String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

model Claim {
  id        String   @id @default(cuid())
  companyId String
  vessel    String
  voyageRef String
  port      String
  cargo     String
  cpForm    String   @default("GENCON94")
  cpTerms   String?  // JSON-serialised CpTerms
  status    String   @default("draft")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator      User?               @relation("ClaimCreator", fields: [createdBy], references: [id])
  documents    Document[]
  sofEvents    SofEvent[]
  calculations LaytimeCalculation[]

  @@index([companyId])
}

model Document {
  id               String   @id @default(cuid())
  claimId          String
  storagePath      String
  originalFilename String
  mime             String
  pageCount        Int?
  extractionStatus String   @default("pending") // pending | extracting | extracted | failed
  createdAt        DateTime @default(now())

  claim    Claim      @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sofEvents SofEvent[]

  @@index([claimId])
}

model SofEvent {
  id           String   @id @default(cuid())
  claimId      String
  documentId   String
  occurredAt   DateTime
  eventType    String
  rawText      String
  page         Int
  bbox         String   // JSON: { x, y, width, height }
  confidence   Float
  source       String   // 'ai' | 'user'
  status       String   // 'suggested' | 'accepted' | 'edited' | 'rejected'
  aiReasoning  String?
  createdAt    DateTime @default(now())

  claim      Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  clauseFlags ClauseFlag[]

  @@index([claimId])
  @@index([documentId])
}

model LaytimeCalculation {
  id              String   @id @default(cuid())
  claimId         String
  inputs          String   // JSON-serialised inputs
  breakdown       String   // JSON-serialised breakdown rows
  usedHours       Float
  allowedHours    Float
  demurrageAmount Float?
  despatchAmount  Float?
  currency        String   @default("USD")
  computedAt      DateTime @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model ClauseFlag {
  id        String   @id @default(cuid())
  eventId   String
  clauseRef String
  severity  String   // 'info' | 'warning' | 'critical'
  note      String
  createdAt DateTime @default(now())

  event SofEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}
